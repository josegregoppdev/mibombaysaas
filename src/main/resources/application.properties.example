# ============================================================
# PLANTILLA — Copiá este archivo como application.properties
# o usá los perfiles application-dev.properties / application-prod.properties
# ============================================================

spring.application.name=mibombay
spring.profiles.active=dev

# --- Base de datos (MySQL) ---
# URL de conexión JDBC. createDatabaseIfNotExist=true crea la BD la primera vez
spring.datasource.url=jdbc:mysql://HOST:PUERTO/NOMBRE_BD?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
# Usuario de MySQL
spring.datasource.username=TU_USUARIO
# Contraseña de MySQL
spring.datasource.password=TU_CONTRASEÑA
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# --- JPA / Hibernate ---
# update: crea/actualiza tablas automáticamente (útil en dev)
# validate: solo valida que coincidan con las entidades (recomendado en prod)
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.properties.hibernate.format_sql=true

# --- Thymeleaf ---
# false en dev para ver cambios sin reiniciar; true en prod para performance
spring.thymeleaf.cache=false

# --- Logging ---
# DEBUG en dev para ver qué hace Spring Security; WARN en prod
logging.level.org.springframework.security=DEBUG
